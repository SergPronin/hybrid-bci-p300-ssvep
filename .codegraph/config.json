{
  "version": 1,
  "include": [
    "**/*.py"
  ],
  "exclude": [
    "**/.git/**",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/venv/**",
    "**/site-packages/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "**/*.egg-info/**",
    "**/repomix-output.xml",
    "**/data/**",
    "**/scripts/**",
    "**/.idea/**"
  ],
  "languages": ["python"],
  "frameworks": [],
  "maxFileSize": 1048576,
  "extractDocstrings": true,
  "trackCallSites": true
}
